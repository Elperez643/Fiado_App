#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android signing and local SDK configuration
android/.gradle/
android/local.properties
android/key.properties
*.jks
*.keystore

# iOS/macOS local artifacts
ios/Pods/
macos/Pods/
**/DerivedData/
*.mobileprovision
*.p12

# .NET / Visual Studio
**/bin/
**/obj/
.vs/
TestResults/
*.user
*.suo
*.userosscache
