{
  "ConnectionStrings": {
    "FiadoDb": "Server=<LOCAL_OR_REMOTE_SERVER>;Database=<DATABASE_NAME>;User Id=<USER_OR_USE_TRUSTED_CONNECTION>;Password=<LOCAL_SECRET>;TrustServerCertificate=True;Encrypt=False;"
  },
  "Jwt": {
    "Issuer": "FiadoApp",
    "Audience": "FiadoApp",
    "Secret": "<LOCAL_DEVELOPMENT_SECRET>"
  },
  "Payments": {
